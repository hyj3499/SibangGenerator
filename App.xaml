<Application x:Class="SibangGenerator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SibangGenerator.Converters"
             StartupUri="Views/MainWindow.xaml">
  <Application.Resources>

    <conv:SeverityBrushConverter x:Key="SevBrush"/>
    <conv:SeverityRowBrushConverter x:Key="SevRowBrush"/>
    <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    <conv:CountToBrushConverter x:Key="CountBrush"/>
    <conv:SectionHeaderBrushConverter x:Key="SectionBrush"/>

    <!-- 팔레트: 종이/잉크. 정보 밀도 높은 검사 도구에 맞춘 저채도 -->
    <SolidColorBrush x:Key="Ink"      Color="#12161C"/>
    <SolidColorBrush x:Key="Paper"    Color="#E8E6E0"/>
    <SolidColorBrush x:Key="Panel"    Color="#F4F3EF"/>
    <SolidColorBrush x:Key="Rule"     Color="#C7C4BB"/>
    <SolidColorBrush x:Key="RuleHard" Color="#8F8B80"/>
    <SolidColorBrush x:Key="Dim"      Color="#6B675E"/>
    <SolidColorBrush x:Key="Amber"    Color="#B8790C"/>
    <SolidColorBrush x:Key="Alert"    Color="#A4302A"/>
    <SolidColorBrush x:Key="Ok"       Color="#2F6146"/>
    <SolidColorBrush x:Key="Sel"      Color="#1B4F8F"/>
    <SolidColorBrush x:Key="SelWash"  Color="#1A1B4F8F" Opacity="1"/>
    <SolidColorBrush x:Key="AlertWash" Color="#1EA4302A"/>
    <SolidColorBrush x:Key="AmberWash" Color="#22B8790C"/>

    <FontFamily x:Key="Mono">Consolas, D2Coding, monospace</FontFamily>
    <FontFamily x:Key="Sans">Malgun Gothic, Segoe UI</FontFamily>

    <!-- 버튼 -->
    <Style x:Key="Btn" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource Paper}"/>
      <Setter Property="Foreground" Value="{StaticResource Ink}"/>
      <Setter Property="BorderBrush" Value="{StaticResource RuleHard}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontFamily" Value="{StaticResource Sans}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource Ink}"/>
                <Setter Property="Foreground" Value="{StaticResource Paper}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35"/>
                <Setter Property="Cursor" Value="Arrow"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="Background" Value="{StaticResource Ink}"/>
      <Setter Property="Foreground" Value="{StaticResource Paper}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Ink}"/>
    </Style>

    <!-- 스텝바 전용. Btn 스타일의 hover 트리거가 Bg 바인딩을 덮어쓰지 않도록 분리 -->
    <Style x:Key="StepBtn" TargetType="Button">
      <Setter Property="BorderBrush" Value="{StaticResource Rule}"/>
      <Setter Property="BorderThickness" Value="0,0,1,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.32"/>
          <Setter Property="Cursor" Value="Arrow"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- 섹션 제목 -->
    <Style x:Key="Eyebrow" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource Dim}"/>
    </Style>

    <Style x:Key="Hint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{StaticResource Dim}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="LineHeight" Value="16"/>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Background" Value="{StaticResource Paper}"/>
      <Setter Property="BorderBrush" Value="{StaticResource RuleHard}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="6,4"/>
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{StaticResource Ink}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

  </Application.Resources>
</Application>
