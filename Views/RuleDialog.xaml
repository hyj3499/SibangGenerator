<Window x:Class="SibangGenerator.Views.RuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="변환 규칙 추가" Height="620" Width="620"
        Background="{StaticResource Paper}" FontFamily="{StaticResource Sans}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
  <DockPanel>

    <Border DockPanel.Dock="Top" Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Ink}" BorderThickness="0,0,0,1.5" Padding="16,12">
      <StackPanel>
        <TextBlock Text="변환 규칙 추가" FontSize="14" FontWeight="SemiBold"/>
        <TextBlock x:Name="Subtitle" FontFamily="{StaticResource Mono}" FontSize="10.5"
                   Foreground="{StaticResource Sel}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Rule}" BorderThickness="0,1,0,0" Padding="16,10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="취소" Style="{StaticResource Btn}" Margin="0,0,7,0" Click="Cancel_Click"/>
        <Button x:Name="BtnAdd" Content="추가" Style="{StaticResource BtnPrimary}"
                IsEnabled="False" Click="Add_Click"/>
      </StackPanel>
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="16">

        <ListBox x:Name="KindList" BorderThickness="0" Background="Transparent"
                 HorizontalContentAlignment="Stretch" SelectionChanged="Kind_Select">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{StaticResource Rule}" BorderThickness="1"
                      Background="{StaticResource Panel}" Padding="11" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding Sid}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                             FontWeight="Bold" Foreground="{StaticResource Sel}" Width="26"
                             VerticalAlignment="Top"/>
                  <StackPanel MaxWidth="500">
                    <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Desc}" FontSize="11.5" TextWrapping="Wrap"
                               Foreground="{StaticResource Dim}" Margin="0,2,0,0"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- A / B / C 필터 옵션 (T3 전용) -->
        <StackPanel x:Name="FilterBox" Visibility="Collapsed" Margin="0,14,0,0">
          <TextBlock Text="모델 필터" Style="{StaticResource Eyebrow}" Margin="0,0,0,10"/>

          <Border BorderBrush="{StaticResource Rule}" BorderThickness="1" Padding="12" Margin="0,0,0,7"
                  Background="{StaticResource Panel}">
            <StackPanel>
              <RadioButton x:Name="RbA" GroupName="Filter" IsChecked="True" FontWeight="SemiBold"
                           Content="A · 원본 그대로"/>
              <TextBlock Style="{StaticResource Hint}" Margin="22,3,0,0"
                         Text="옛 시방의 모든 단락과 모델을 그대로 가져옵니다. 등록한 모델이 이 단락에 없으면 로그에 경고만 남깁니다."/>
            </StackPanel>
          </Border>

          <Border BorderBrush="{StaticResource Rule}" BorderThickness="1" Padding="12" Margin="0,0,0,7"
                  Background="{StaticResource Panel}">
            <StackPanel>
              <RadioButton x:Name="RbB" GroupName="Filter" FontWeight="SemiBold"
                           Content="B · 등록한 모델만 남김"/>
              <TextBlock Style="{StaticResource Hint}" Margin="22,3,0,0"
                         Text="모델 나열에서 등록 모델만 남기고 나머지는 지웁니다. 등록 모델이 하나도 없는 그룹은 통째로 삭제합니다."/>
              <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource Rule}"
                      BorderThickness="1" Padding="8,5" Margin="22,6,0,0">
                <TextBlock FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Dim}"
                           Text="- A, B, C, D&#x0a;→ - A"/>
              </Border>
            </StackPanel>
          </Border>

          <Border BorderBrush="{StaticResource Rule}" BorderThickness="1" Padding="12"
                  Background="{StaticResource Panel}">
            <StackPanel>
              <RadioButton x:Name="RbC" GroupName="Filter" FontWeight="SemiBold"
                           Content="C · 무관 그룹만 삭제"/>
              <TextBlock Style="{StaticResource Hint}" Margin="22,3,0,0"
                         Text="등록 모델이 하나라도 있는 그룹은 모델 나열을 손대지 않습니다. 하나도 없는 그룹만 삭제합니다."/>
              <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource Rule}"
                      BorderThickness="1" Padding="8,5" Margin="22,6,0,0">
                <TextBlock FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Dim}"
                           Text="- A, B, C, D&#x0a;→ - A, B, C, D  (그대로)"/>
              </Border>
            </StackPanel>
          </Border>

          <TextBlock Style="{StaticResource Hint}" Margin="0,10,0,0"
                     Text="Wi-Fi / Buzzer 표시 모델 줄은 B 옵션에서 해당 모델이 없어도 줄은 남기고 나열만 비웁니다. '표시 제외 모델' 같은 설명문은 절대 건드리지 않습니다."/>
        </StackPanel>

        <!-- 설명만 나오는 규칙들 -->
        <Border x:Name="InfoBox" Visibility="Collapsed" Margin="0,14,0,0"
                Background="{StaticResource Panel}" BorderBrush="{StaticResource Rule}"
                BorderThickness="1" Padding="12">
          <TextBlock x:Name="InfoText" Style="{StaticResource Hint}"/>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
