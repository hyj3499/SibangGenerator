<Window x:Class="SibangGenerator.Views.VersionGroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="모델 추가" Height="480" Width="560"
        Background="{StaticResource Paper}" FontFamily="{StaticResource Sans}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
  <DockPanel>

    <Border DockPanel.Dock="Top" Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Ink}" BorderThickness="0,0,0,1.5" Padding="16,12">
      <StackPanel>
        <TextBlock x:Name="Head" Text="모델 추가" FontSize="14" FontWeight="SemiBold"/>
        <TextBlock Text="버전 마다 모델을 여러개 등록." FontSize="11.5"
                   Foreground="{StaticResource Dim}" Margin="0,2,0,0"/>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Rule}" BorderThickness="0,1,0,0" Padding="16,10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="취소" Style="{StaticResource Btn}" Margin="0,0,7,0" Click="Cancel_Click"/>
        <Button x:Name="BtnOk" Content="추가" Style="{StaticResource BtnPrimary}" Click="Ok_Click"/>
      </StackPanel>
    </Border>

    <StackPanel Margin="16">

      <TextBlock Text="버전" Style="{StaticResource Eyebrow}" Margin="0,0,0,4"/>
      <TextBlock x:Name="VerHint" Style="{StaticResource Hint}" Margin="0,0,0,6"/>
      <ComboBox x:Name="CbVersion" IsEditable="True" IsTextSearchEnabled="False"
                SelectionChanged="Ver_Changed" KeyUp="Ver_Typed"/>

      <TextBlock Text="모델명" Style="{StaticResource Eyebrow}" Margin="0,16,0,4"/>
      <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,6"
                 Text="모델명을 다음과 같이 입력. (예: PREMTBB20.ENCXUAEC, PREMTB200.AKMC, PREMTB200.AKM, PREMTB200.ENCXCOM)"/>
      <TextBox x:Name="TbModels" Height="150" AcceptsReturn="True" TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto" TextChanged="Models_Changed"/>

      <Border Margin="0,10,0,0" Background="{StaticResource Panel}"
              BorderBrush="{StaticResource Rule}" BorderThickness="1" Padding="10">
        <TextBlock x:Name="Preview" Style="{StaticResource Hint}" Text="0개 모델"/>
      </Border>

    </StackPanel>
  </DockPanel>
</Window>
