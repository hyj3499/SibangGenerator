<Window x:Class="SibangGenerator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="시방 생성 · Sibang Generator"
        Height="840" Width="1400" MinHeight="620" MinWidth="1040"
        Background="{StaticResource Paper}"
        FontFamily="{StaticResource Sans}"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <!-- 문서 한 줄 -->
    <DataTemplate x:Key="LineTpl">
      <Grid Background="{Binding RowBrush}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="52"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Rule}" BorderThickness="0,0,1,0">
          <TextBlock Text="{Binding No}" HorizontalAlignment="Right" Margin="0,0,8,0"
                     FontFamily="{StaticResource Mono}" FontSize="10"
                     Foreground="{StaticResource RuleHard}"/>
        </Border>
        <TextBlock Grid.Column="1" Text="{Binding Text}" Margin="10,0,0,0"
                   FontFamily="{StaticResource Mono}" FontSize="12"
                   TextWrapping="NoWrap" Foreground="{StaticResource Ink}"/>
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ══ 상단 ══ -->
    <Border Grid.Row="0" Background="{StaticResource Panel}"
            BorderBrush="{StaticResource RuleHard}" BorderThickness="0,0,0,1.5">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,10" VerticalAlignment="Center">
          <TextBlock Text="시방 생성" FontSize="15" FontWeight="Bold"/>
          <TextBlock Text="SIBANG GENERATOR" Margin="10,0,16,0" VerticalAlignment="Bottom"
                     FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{StaticResource Dim}"/>
        </StackPanel>

        <ItemsControl Grid.Column="1" x:Name="Stepper" VerticalAlignment="Stretch">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Style="{StaticResource StepBtn}" Tag="{Binding No}" Click="Step_Click"
                      IsEnabled="{Binding Enabled}" Padding="16,0" Height="41"
                      Background="{Binding Bg}" Foreground="{Binding Fg}">
                <StackPanel Orientation="Horizontal">
                  <Border Width="19" Height="19" CornerRadius="10" BorderThickness="1"
                          BorderBrush="{Binding Fg}" Background="{Binding NumBg}">
                    <TextBlock Text="{Binding No}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontFamily="{StaticResource Mono}" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding NumFg}"/>
                  </Border>
                  <TextBlock Text="{Binding Label}" Margin="9,0,0,0" VerticalAlignment="Center" FontSize="12.5"/>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
          <Button x:Name="BtnSave" Content="규칙 저장" Style="{StaticResource Btn}"
                  Margin="0,0,6,0" IsEnabled="False" Click="Save_Click"/>
          <Button Content="불러오기" Style="{StaticResource Btn}" Margin="0,0,6,0" Click="Load_Click"/>
          <Button x:Name="BtnRun" Content="시방 생성" Style="{StaticResource BtnPrimary}"
                  IsEnabled="False" Click="Run_Click"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">

      <!-- ─── 1. 기존 시방 첨부 ─── -->
      <Grid x:Name="P1">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="700">
          <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource RuleHard}"
                  BorderThickness="1" Padding="48,44" AllowDrop="True"
                  Drop="Drop_File" DragOver="Drag_Over">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock Text="기존 시방 TXT를 첨부하세요" FontSize="23" FontWeight="SemiBold"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="이 문서의 레이아웃을 따라 새 시방을 만듭니다."
                         Margin="0,8,0,22" HorizontalAlignment="Center"
                         Foreground="{StaticResource Dim}" FontSize="13"/>
              <Button Content="파일 선택" Style="{StaticResource BtnPrimary}"
                      HorizontalAlignment="Center" Padding="20,7" Click="Pick_File"/>
              <TextBlock Text="드래그 앤 드롭 · UTF-8 / EUC-KR 자동 감지"
                         Margin="0,18,0,0" HorizontalAlignment="Center"
                         FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Dim}"/>
            </StackPanel>
          </Border>
          <TextBlock Margin="0,24,0,0" TextAlignment="Center" TextWrapping="Wrap"
                     FontSize="12" Foreground="{StaticResource Dim}" LineHeight="20"
                     Text="Ver 0.00.0"/>
        </StackPanel>
      </Grid>

      <!-- ─── 2. 경로 + 버전 그룹 ─── -->
      <Grid x:Name="P2" Visibility="Collapsed">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="470"/>
        </Grid.ColumnDefinitions>

        <!-- 좌: 버전 그룹 -->
        <DockPanel Grid.Column="0">
          <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" Height="41"
                  BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0">
              <TextBlock Text="등록된 모델 · 버전 그룹" Style="{StaticResource Eyebrow}" VerticalAlignment="Center"/>
              <TextBlock x:Name="GroupInfo" HorizontalAlignment="Right" VerticalAlignment="Center"
                         FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Dim}"/>
            </DockPanel>
          </Border>

          <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Rule}"
                  BorderThickness="0,1,0,0" Padding="14,12" Background="{StaticResource Panel}">
            <Button x:Name="BtnAddGroup" Content="+  모델 추가" Style="{StaticResource BtnPrimary}"
                    Padding="0,9" Click="AddGroup_Click"/>
          </Border>

          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <TextBlock x:Name="GroupEmpty" Margin="24,50" TextAlignment="Center"
                         Style="{StaticResource Hint}"
                         Text="아래 [+ 모델 추가] 를 눌러&#x0a;버전 하나에 모델 여러 개를 묶어 등록하세요.&#x0a;&#x0a;(예: 1.007a 버전: PREMTBB20.ENCXUAEC, PREMTB200B.ENCXCOM)&#x0a;(예: 1.008a 버전: PREMTB200.AKMC, PREMTB200.AKM)"/>

              <ItemsControl x:Name="GroupList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource RuleHard}"
                            BorderThickness="1" Margin="12,6">
                      <StackPanel>
                        <!-- 헤더: 버전 + 삭제 -->
                        <Border Background="{StaticResource Panel}" Padding="12,8"
                                BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
                          <DockPanel>
                            <Border Background="{StaticResource Ink}" Padding="9,3" CornerRadius="2">
                              <TextBlock Text="{Binding Version}" Foreground="{StaticResource Paper}"
                                         FontFamily="{StaticResource Mono}" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                            <Button Content="✕" DockPanel.Dock="Right" Style="{StaticResource Btn}"
                                    Padding="6,0" BorderThickness="0" Background="Transparent"
                                    Tag="{Binding Version}" Click="DelGroup_Click"/>
                            <Button Content="편집" DockPanel.Dock="Right" Style="{StaticResource Btn}"
                                    Padding="8,2" Margin="0,0,5,0"
                                    Tag="{Binding Version}" Click="EditGroup_Click"/>
                            <TextBlock Text="{Binding Summary}" Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontSize="11.5" Foreground="{StaticResource Dim}"/>
                          </DockPanel>
                        </Border>
                        <!-- 모델 목록 -->
                        <ItemsControl ItemsSource="{Binding Models}" Margin="12,8">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Rule}"
                                      BorderThickness="1" Padding="7,3" Margin="0,0,5,5">
                                <TextBlock Text="{Binding}" FontFamily="{StaticResource Mono}" FontSize="11"/>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- 조회 결과 -->
              <Border x:Name="ResolveBox" Visibility="Collapsed" Margin="12,10,12,20"
                      Background="{StaticResource Panel}" BorderBrush="{StaticResource Rule}"
                      BorderThickness="1" Padding="12">
                <StackPanel>
                  <DockPanel Margin="0,0,0,4">
                    <TextBlock Text="조회 결과" Style="{StaticResource Eyebrow}" VerticalAlignment="Center"/>
                    <Button Content="↻ 갱신" Style="{StaticResource Btn}" Padding="10,3"
                            HorizontalAlignment="Right" Click="RefreshResolve_Click"/>
                  </DockPanel>
                  <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,8"
                             Text="행을 클릭하면 BOM 을 직접 지정할 수 있음. 직접 지정한 값은 엑셀 조회보다 우선함."/>

                  <ListBox x:Name="ResolveList" BorderThickness="0" Background="Transparent"
                           HorizontalContentAlignment="Stretch"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                           MouseDoubleClick="Resolve_DoubleClick">
                    <ListBox.ItemContainerStyle>
                      <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                      </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="2,3">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="66"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding Name}"
                                     FontFamily="{StaticResource Mono}" FontSize="11"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Grid.Column="1" Text="{Binding Version}"
                                     FontFamily="{StaticResource Mono}" FontSize="11"
                                     Foreground="{StaticResource Dim}"/>
                          <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="11"
                                     TextTrimming="CharacterEllipsis"
                                     Foreground="{Binding StatusSev, Converter={StaticResource SevBrush}}"/>
                          <Border Grid.Column="3" Background="{StaticResource Sel}" Padding="5,1"
                                  CornerRadius="2" Margin="6,0,0,0"
                                  Visibility="{Binding IsOverridden, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="직접 지정" Foreground="White"
                                       FontFamily="{StaticResource Mono}" FontSize="9"/>
                          </Border>
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>

        <!-- 우: 경로 설정 -->
        <Border Grid.Column="1" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource RuleHard}" BorderThickness="1.5,0,0,0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Height="41" BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
              <TextBlock Text="경로 · 전역 설정" Style="{StaticResource Eyebrow}" Margin="14,0" VerticalAlignment="Center"/>
            </Border>

            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Rule}"
                    BorderThickness="0,1,0,0" Padding="14,12">
              <StackPanel>
                <Button x:Name="BtnNext2" Content="구조 분석으로  →" Style="{StaticResource BtnPrimary}"
                        Padding="0,9" Click="Next2_Click" IsEnabled="False"/>
                <TextBlock x:Name="Next2Hint" Style="{StaticResource Hint}" TextAlignment="Center" Margin="0,7,0,0"/>
              </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="14">

                <TextBlock Text="펌웨어 루트 경로" Style="{StaticResource Eyebrow}" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,6"
                           Text="이 아래의 {BOM}_{Ver} 폴더를 직접 읽습니다. 폴더명에서 가능한 버전 목록을 수집합니다."/>
                <DockPanel>
                  <Button Content="…" Style="{StaticResource Btn}" Width="32" Padding="0"
                          DockPanel.Dock="Right" Margin="5,0,0,0" Click="PickRoot_Click"/>
                  <TextBox x:Name="TbRoot" Text="D:\FW\Release" TextChanged="Path_Changed"/>
                </DockPanel>
                <TextBlock x:Name="RootInfo" Style="{StaticResource Hint}" Margin="0,4,0,0"/>

                <TextBlock Text="BOM 엑셀 경로" Style="{StaticResource Eyebrow}" Margin="0,14,0,4"/>
                <DockPanel>
                  <Button Content="…" Style="{StaticResource Btn}" Width="32" Padding="0"
                          DockPanel.Dock="Right" Margin="5,0,0,0" Click="PickExcel_Click"/>
                  <TextBox x:Name="TbExcel" Text="D:\BOM\model_bom.xlsx" TextChanged="Path_Changed"/>
                </DockPanel>

                <Border Margin="0,8,0,0" Background="{StaticResource Paper}"
                        BorderBrush="{StaticResource Rule}" BorderThickness="1" Padding="10">
                  <StackPanel>
                    <TextBlock Text="엑셀 조회 설정" Style="{StaticResource Eyebrow}" Margin="0,0,0,6"/>
                    <TextBlock Text="시트명" Style="{StaticResource Eyebrow}" FontSize="9" Margin="0,0,0,3"/>
                    <TextBox x:Name="TbSheet" Text="Sheet1"/>
                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="모델명 매칭 열" Style="{StaticResource Eyebrow}" FontSize="9" Margin="0,0,0,3"/>
                        <TextBox x:Name="TbMcol" Text="G"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Text="BOM 열" Style="{StaticResource Eyebrow}" FontSize="9" Margin="0,0,0,3"/>
                        <TextBox x:Name="TbVcol" Text="K"/>
                      </StackPanel>
                    </Grid>
                    <TextBlock Style="{StaticResource Hint}" Margin="0,4,0,0"
                               Text="매칭 열은 쉼표로 여러 개 지정할 수 있습니다 (예: G, H, I)."/>
                    <CheckBox x:Name="ChkSplit" IsChecked="True" Margin="0,9,0,0" Content="셀 내부 줄바꿈 분해"/>
                    <TextBlock Style="{StaticResource Hint}" Margin="22,2,0,0"
                               Text="한 셀에 여러 모델이 있을 때 분해 후 정확일치. ENCXUAEC 와 ENCXUAECRC 를 구분합니다."/>
                  </StackPanel>
                </Border>

                <TextBlock Text="CPU (모든 4-N 블록 공통)" Style="{StaticResource Eyebrow}" Margin="0,14,0,4"/>
                <TextBox x:Name="TbCpu" Text="ESP32-S3R16 (ESPRESSIF)"/>

                <TextBlock Text="F/W 고정 파일 순서" Style="{StaticResource Eyebrow}" Margin="0,14,0,4"/>
                <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,6"
                           Text="괄호 맨 앞에 이 순서로 배치. 나머지 파일은 파일명 오름차순으로 뒤에 붙습니다."/>
                <TextBox x:Name="TbFixed" Text="bootloader, partition-table, lgha_new_standard_rcu"/>

                <Separator Margin="0,16" Background="{StaticResource Rule}"/>

                <TextBlock Text="모델 사전" Style="{StaticResource Eyebrow}" Margin="0,14,0,4"/>
                <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,6"
                           Text="기존 시방에서 자동 수집됩니다. 모델 나열 줄을 판별하는 데 쓰입니다."/>
                <TextBox x:Name="TbDict" Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" TextChanged="Dict_Changed"/>
                <TextBlock x:Name="DictN" Style="{StaticResource Hint}" Margin="0,4,0,0"/>

              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>

      <!-- ─── 3. 구조 분석 ─── -->
      <Grid x:Name="P3" Visibility="Collapsed">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="430"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
          <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" Height="41"
                  BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0">
              <TextBlock x:Name="P3Title" Text="원문 · 구조 분석" Style="{StaticResource Eyebrow}" VerticalAlignment="Center"/>
              <TextBlock x:Name="EnInfo" HorizontalAlignment="Right" VerticalAlignment="Center"
                         FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Dim}"/>
            </DockPanel>
          </Border>
          <ListBox x:Name="Lv3" BorderThickness="0" Background="{StaticResource Paper}"
                   ItemTemplate="{StaticResource LineTpl}" HorizontalContentAlignment="Stretch"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto" SelectionChanged="Lv3_Select">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
              </Style>
            </ListBox.ItemContainerStyle>
          </ListBox>
        </DockPanel>

        <Border Grid.Column="1" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource RuleHard}" BorderThickness="1.5,0,0,0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Height="41" BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
              <TextBlock Text="분석 결과" Style="{StaticResource Eyebrow}" Margin="14,0" VerticalAlignment="Center"/>
            </Border>
            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Rule}"
                    BorderThickness="0,1,0,0" Padding="14,12">
              <StackPanel>
                <Button x:Name="BtnNext3" Content="변환 규칙으로  →" Style="{StaticResource BtnPrimary}"
                        Padding="0,9" Click="Next3_Click"/>
                <TextBlock x:Name="Next3Hint" Style="{StaticResource Hint}" TextAlignment="Center" Margin="0,7,0,0"/>
              </StackPanel>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="14">
                <CheckBox x:Name="ChkEn" Content="영문 파트 포함" Checked="En_Toggle" Unchecked="En_Toggle"
                          FontWeight="SemiBold"/>
                <TextBlock Style="{StaticResource Hint}" Margin="22,3,0,14"
                           Text="체크하면 아래에서 영문 시작 라인을 클릭합니다. 한글 단락에 건 규칙이 짝지어진 영문 단락에도 자동 적용됩니다."/>

                <StackPanel x:Name="EnBox" Visibility="Collapsed" Margin="0,0,0,14">
                  <TextBlock Text="영문 경계" Style="{StaticResource Eyebrow}" Margin="0,0,0,5"/>
                  <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,6"
                             Text="왼쪽에서 영문이 시작되는 라인을 클릭하세요."/>
                  <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource RuleHard}"
                          BorderThickness="1" Padding="8,5">
                    <TextBlock x:Name="EnLine" Text="아직 선택 안 함" FontFamily="{StaticResource Mono}"
                               FontSize="11" Foreground="{StaticResource Dim}" TextTrimming="CharacterEllipsis"/>
                  </Border>
                </StackPanel>

                <TextBlock Text="추출된 단락" Style="{StaticResource Eyebrow}" Margin="0,0,0,6"/>
                <ItemsControl x:Name="BlockSummary">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="48"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Num}" FontFamily="{StaticResource Mono}"
                                   FontSize="10.5" Foreground="{StaticResource Dim}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="11.5"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2" Text="{Binding Anchor}" FontFamily="{StaticResource Mono}"
                                   FontSize="10" Foreground="{StaticResource Sel}"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>

      <!-- ─── 4. 변환 규칙 ─── -->
      <Grid x:Name="P4" Visibility="Collapsed">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
          <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" Height="41"
                  BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0">
              <TextBlock Text="단락 · 선택 후 [+ 규칙 추가]" Style="{StaticResource Eyebrow}" VerticalAlignment="Center"/>
              <TextBlock x:Name="BlkInfo" HorizontalAlignment="Right" VerticalAlignment="Center"
                         FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Dim}"/>
            </DockPanel>
          </Border>

          <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}"
                  BorderBrush="{StaticResource Rule}" BorderThickness="0,1,0,0" Padding="14,10">
            <DockPanel>
              <TextBlock x:Name="EnNote" DockPanel.Dock="Left" Style="{StaticResource Hint}"
                         VerticalAlignment="Center" MaxWidth="420"/>
              <Button x:Name="BtnAddRule" Content="+  규칙 추가" Style="{StaticResource BtnPrimary}"
                      HorizontalAlignment="Right" Padding="18,7" Click="AddRule_Click" IsEnabled="False"/>
            </DockPanel>
          </Border>

          <ListBox x:Name="BlockList" BorderThickness="0" Background="{StaticResource Paper}"
                   HorizontalContentAlignment="Stretch"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   SelectionChanged="Block_Select"
                   MouseDoubleClick="Block_DoubleClick">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <Border x:Name="bd" Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                          <Setter TargetName="bd" Property="Background" Value="#1A1B4F8F"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
                  <StackPanel>
                    <!-- 최상위 섹션이면 연노랑 -->
                    <Border Background="{Binding IsSection, Converter={StaticResource SectionBrush}}"
                            Padding="14,7" BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="52"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Num}" FontFamily="{StaticResource Mono}"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Dim}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" CornerRadius="9" Padding="7,2" VerticalAlignment="Center"
                                Background="{Binding ModelCount, Converter={StaticResource CountBrush}}">
                          <TextBlock FontFamily="{StaticResource Mono}" FontSize="9.5" FontWeight="SemiBold"
                                     Foreground="{StaticResource Paper}">
                            <Run Text="모델 "/><Run Text="{Binding ModelCount, Mode=OneWay}"/>
                          </TextBlock>
                        </Border>
                      </Grid>
                    </Border>
                    <ScrollViewer MaxHeight="170" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding Preview}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                              </Grid.ColumnDefinitions>
                              <Border Grid.Column="0" Background="{StaticResource Panel}"
                                      BorderBrush="{StaticResource Rule}" BorderThickness="0,0,1,0">
                                <TextBlock Text="{Binding No}" HorizontalAlignment="Right" Margin="0,0,8,0"
                                           FontFamily="{StaticResource Mono}" FontSize="10"
                                           Foreground="{StaticResource RuleHard}"/>
                              </Border>
                              <TextBlock Grid.Column="1" Text="{Binding Text}" Margin="10,0,0,0"
                                         FontFamily="{StaticResource Mono}" FontSize="11.5"/>
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>

        <!-- 우: 컴팩트 규칙 카드 -->
        <Border Grid.Column="1" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource RuleHard}" BorderThickness="1.5,0,0,0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Height="41" BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
              <DockPanel Margin="14,0">
                <TextBlock Text="변환 규칙" Style="{StaticResource Eyebrow}" VerticalAlignment="Center"/>
                <TextBlock x:Name="RuleN" Text="0개" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Dim}"/>
              </DockPanel>
            </Border>

            <!-- 순서 바꾸기 -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Rule}"
                    BorderThickness="0,1,0,0" Padding="10,8">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnUp" Content="↑ 위로" Style="{StaticResource Btn}" Padding="12,4"
                        Margin="0,0,5,0" Click="MoveUp_Click" IsEnabled="False"/>
                <Button x:Name="BtnDown" Content="↓ 아래로" Style="{StaticResource Btn}" Padding="12,4"
                        Margin="0,0,5,0" Click="MoveDown_Click" IsEnabled="False"/>
                <Button x:Name="BtnEditRule" Content="설정 수정" Style="{StaticResource Btn}" Padding="12,4"
                        Click="EditRule_Click" IsEnabled="False"/>
              </StackPanel>
            </Border>

            <TextBlock x:Name="RuleEmpty" DockPanel.Dock="Top" Margin="24,44" TextAlignment="Center"
                       Style="{StaticResource Hint}"
                       Text="왼쪽 단락을 선택하고&#x0a;[+ 규칙 추가] 를 누르세요.&#x0a;&#x0a;규칙 없는 단락은 원본 그대로 복사됩니다."/>

            <ListBox x:Name="RuleList" BorderThickness="0" Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="Rule_Select" MouseDoubleClick="Rule_DoubleClick">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <!-- 컴팩트: 한 줄 헤더 + 한 줄 상세 -->
                  <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource RuleHard}"
                          BorderThickness="1" Margin="8,4" Padding="0">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>

                      <Grid Grid.Row="0" Margin="9,6,4,4">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="26"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ShortId}" FontFamily="{StaticResource Mono}"
                                   FontSize="10" FontWeight="Bold" Foreground="{StaticResource Sel}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding KindLabel}" FontSize="12" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="✕" Style="{StaticResource Btn}"
                                Padding="0" Width="20" Height="20" BorderThickness="0"
                                Background="Transparent" FontSize="11"
                                Tag="{Binding No}" Click="DelRule_Click"/>
                      </Grid>

                      <StackPanel Grid.Row="1" Margin="9,0,9,7">
                        <TextBlock Text="{Binding Title}" FontSize="10.5" Foreground="{StaticResource Dim}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Detail}" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Ink}" TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>
      </Grid>

      <!-- ─── 5. 미리보기 ─── -->
      <Grid x:Name="P5" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource RuleHard}" BorderThickness="0,0,0,1.5">
          <UniformGrid Rows="1">
            <StackPanel Margin="14,11">
              <TextBlock Text="오류" Style="{StaticResource Eyebrow}"/>
              <TextBlock x:Name="SumE" Text="0" FontFamily="{StaticResource Mono}" FontSize="22"
                         FontWeight="SemiBold" Foreground="{StaticResource Alert}"/>
            </StackPanel>
            <StackPanel Margin="14,11">
              <TextBlock Text="경고" Style="{StaticResource Eyebrow}"/>
              <TextBlock x:Name="SumW" Text="0" FontFamily="{StaticResource Mono}" FontSize="22"
                         FontWeight="SemiBold" Foreground="{StaticResource Amber}"/>
            </StackPanel>
            <StackPanel Margin="14,11">
              <TextBlock Text="생성 줄 수" Style="{StaticResource Eyebrow}"/>
              <TextBlock x:Name="SumL" Text="0" FontFamily="{StaticResource Mono}" FontSize="22"
                         FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel Margin="14,11">
              <TextBlock Text="4-N 블록" Style="{StaticResource Eyebrow}"/>
              <TextBlock x:Name="SumB" Text="0" FontFamily="{StaticResource Mono}" FontSize="22"
                         FontWeight="SemiBold" Foreground="{StaticResource Ok}"/>
            </StackPanel>
          </UniformGrid>
        </Border>

        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
          </Grid.ColumnDefinitions>

          <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" Height="34"
                    BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
              <TextBlock Text="기존 시방" Style="{StaticResource Eyebrow}" Margin="14,0" VerticalAlignment="Center"/>
            </Border>
            <ListBox x:Name="LvOld" BorderThickness="0" Background="{StaticResource Paper}"
                     ItemTemplate="{StaticResource LineTpl}" HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                  <Setter Property="Padding" Value="0"/>
                  <Setter Property="BorderThickness" Value="0"/>
                </Style>
              </ListBox.ItemContainerStyle>
            </ListBox>
          </DockPanel>

          <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" Height="34"
                    BorderBrush="{StaticResource RuleHard}" BorderThickness="1.5,0,0,1">
              <TextBlock Text="새 시방" Style="{StaticResource Eyebrow}" Margin="14,0" VerticalAlignment="Center"/>
            </Border>
            <Border BorderBrush="{StaticResource RuleHard}" BorderThickness="1.5,0,0,0">
              <ListBox x:Name="LvNew" BorderThickness="0" Background="{StaticResource Paper}"
                       ItemTemplate="{StaticResource LineTpl}" HorizontalContentAlignment="Stretch"
                       ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                  </Style>
                </ListBox.ItemContainerStyle>
              </ListBox>
            </Border>
          </DockPanel>

          <Border Grid.Column="2" Background="{StaticResource Panel}"
                  BorderBrush="{StaticResource RuleHard}" BorderThickness="1.5,0,0,0">
            <DockPanel>
              <Border DockPanel.Dock="Top" Height="34" BorderBrush="{StaticResource Rule}" BorderThickness="0,0,0,1">
                <TextBlock Text="로그" Style="{StaticResource Eyebrow}" Margin="14,0" VerticalAlignment="Center"/>
              </Border>
              <ListBox x:Name="LogBox" BorderThickness="0" Background="Transparent"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                      <Border Background="{Binding Sev, Converter={StaticResource SevBrush}}"
                              Padding="5,1" Margin="0,0,7,0" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Label}" Foreground="White"
                                   FontFamily="{StaticResource Mono}" FontSize="9" FontWeight="SemiBold"/>
                      </Border>
                      <TextBlock Text="{Binding Msg}" FontSize="11" TextWrapping="Wrap" MaxWidth="270"
                                 Foreground="{StaticResource Ink}"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource RuleHard}" BorderThickness="0,1.5,0,0" Padding="14,10">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="로그 저장" Style="{StaticResource Btn}" Margin="0,0,7,0" Click="SaveLog_Click"/>
            <Button Content="새 시방 저장" Style="{StaticResource BtnPrimary}" Padding="18,6" Click="SaveSpec_Click"/>
          </StackPanel>
        </Border>
      </Grid>

    </Grid>

    <Border Grid.Row="2" Background="{StaticResource Panel}"
            BorderBrush="{StaticResource RuleHard}" BorderThickness="0,1.5,0,0" Padding="14,5">
      <TextBlock x:Name="Status" Text="기존 시방 TXT를 첨부하세요."
                 FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Dim}"/>
    </Border>
  </Grid>
</Window>
