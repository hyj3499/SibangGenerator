<Window x:Class="SibangGenerator.Views.BomOverrideDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BOM 직접 지정" Height="380" Width="500"
        Background="{StaticResource Paper}" FontFamily="{StaticResource Sans}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
  <DockPanel>

    <Border DockPanel.Dock="Top" Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Ink}" BorderThickness="0,0,0,1.5" Padding="16,12">
      <StackPanel>
        <TextBlock x:Name="Head" FontSize="14" FontWeight="SemiBold"/>
        <TextBlock x:Name="Sub" FontFamily="{StaticResource Mono}" FontSize="10.5"
                   Foreground="{StaticResource Dim}" Margin="0,2,0,0"/>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}"
            BorderBrush="{StaticResource Rule}" BorderThickness="0,1,0,0" Padding="16,10">
      <DockPanel>
        <Button x:Name="BtnClear" Content="직접 지정 해제" Style="{StaticResource Btn}"
                DockPanel.Dock="Left" Click="Clear_Click"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="취소" Style="{StaticResource Btn}" Margin="0,0,7,0" Click="Cancel_Click"/>
          <Button x:Name="BtnOk" Content="적용" Style="{StaticResource BtnPrimary}" Click="Ok_Click"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <StackPanel Margin="16">

      <TextBlock Text="현재 조회 결과" Style="{StaticResource Eyebrow}" Margin="0,0,0,4"/>
      <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Rule}"
              BorderThickness="1" Padding="10,7">
        <TextBlock x:Name="Current" FontSize="11.5" TextWrapping="Wrap"/>
      </Border>

      <TextBlock Text="BOM 직접 지정" Style="{StaticResource Eyebrow}" Margin="0,16,0,4"/>
      <TextBlock Style="{StaticResource Hint}" Margin="0,0,0,6"
                 Text="BOM 직접 지정 시 입력한 값이 엑셀 조회보다 우선하며, 제품버전 재생성(T2)도 이 값을 씀."/>
      <ComboBox x:Name="CbBom" IsEditable="True" IsTextSearchEnabled="False"
                KeyUp="Bom_Typed" SelectionChanged="Bom_Changed"/>

      <Border Margin="0,12,0,0" Background="{StaticResource Panel}"
              BorderBrush="{StaticResource Rule}" BorderThickness="1" Padding="10">
        <StackPanel>
          <TextBlock x:Name="FolderCheck" FontSize="11.5" TextWrapping="Wrap"/>
          <TextBlock x:Name="FileList" FontFamily="{StaticResource Mono}" FontSize="10"
                     Foreground="{StaticResource Dim}" TextWrapping="Wrap" Margin="0,5,0,0"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </DockPanel>
</Window>
